                      "if (data.token) {",
                      "    pm.collectionVariables.set(\"bearerToken\", data.token);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}"
                },
                "url": {
                  "raw": "{{authServiceUrl}}/login",
                  "host": ["{{authServiceUrl}}"],
                  "path": ["login"]
