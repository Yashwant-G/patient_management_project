              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api-docs",
                "auth"
              ]
            },
            "description": "Gateway route that rewrites to the auth service OpenAPI document."
          },
          "response": []
        }
      ]
    }
  ]
}
