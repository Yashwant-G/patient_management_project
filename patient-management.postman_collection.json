      "name": "Auth APIs",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login request succeeded\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = {};",
                  "try {",
                  "    data = pm.response.json();",
                  "} catch (e) {",
                  "    data = {};",
                  "}",
                  "",
                  "if (data.token) {",
                  "    pm.collectionVariables.set(\"bearerToken\", data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticates a user and stores the returned JWT in the collection variable `bearerToken`."
