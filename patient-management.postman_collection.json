    {
      "name": "Direct Service Access",
      "description": "Requests that bypass the API Gateway (port 9000) and hit each microservice directly. Useful for local development and isolated service testing. No rate limiting or JWT gateway filter is applied — the services may still enforce their own auth internally.",
      "item": [
        {
          "name": "Auth Service (port 4005)",
          "item": [
            {
              "name": "Login (direct)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Login request succeeded\", function () {",
